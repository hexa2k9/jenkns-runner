FROM ghcr.io/esphome/esphome:2026.6.2


RUN set -eux \
    && apt-get update \
    && apt-get install -y \
        jq \
        git \
        bash \
        curl \
        nmap \
        unzip \
        openjdk-21-jre \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

ENTRYPOINT [ ]
CMD []
